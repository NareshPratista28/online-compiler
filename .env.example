# ==============================================================================
# Django Core Configurations (Production Readiness)
# ==============================================================================
DJANGO_SECRET_KEY=generate-a-secure-random-secret-key-for-production-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-production-domain.com

# CORS Configurations
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:8000,https://your-laravel-frontend-domain.com

# Database Configurations (MySQL Production)
DB_ENGINE=django.db.backends.mysql
DB_DATABASE=gamification_testing
DB_USERNAME=root
DB_PASSWORD=your_production_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

# ==============================================================================
# Gemini API Configuration
# ==============================================================================
USE_GEMINI=true
GEMINI_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7

# ==============================================================================
# Fallback/Ollama Configuration (Local/Lab)
# ==============================================================================
OLLAMA_MODEL=llama3.1:latest
OLLAMA_BASE_URL=localhost
OLLAMA_TEMPERATURE=0.85
